# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ragbot

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5-nano

# Embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ASR (Speech-to-Text)
WHISPER_MODEL=large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=float16

# Confidence Thresholds
ASR_CONFIDENCE_THRESHOLD=0.70
RETRIEVAL_CONFIDENCE_LOW=0.50
RETRIEVAL_CONFIDENCE_HIGH=0.70
ANSWER_MATCH_THRESHOLD=0.80
LANGUAGE_DETECTION_THRESHOLD=0.85

# Concurrency
MAX_CONCURRENT_REQUESTS=50
REQUEST_TIMEOUT_SECONDS=30

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100

# Logging
LOG_LEVEL=INFO
API_KEY=your-secret-key-here
